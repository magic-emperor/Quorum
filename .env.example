# ─── ATLAS Server ─────────────────────────────────────────────────────────────
# Required: Change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Database location inside container (or local dev path)
DB_PATH=./atlas.db

# Server port
PORT=3001

# Public URL of your deployment (used for Telegram auth links)
PUBLIC_URL=https://atlasconsole.app

# CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://atlasconsole.app

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Optional: Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── AI Provider Keys ─────────────────────────────────────────────────────────
# These are OPTIONAL server-side defaults (users can set their own via the API key manager)
# If set here, they act as fallback for all users

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# ─── Atlas Web (Vite frontend) ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Atlas Console (Expo mobile) ──────────────────────────────────────────────
EXPO_PUBLIC_ATLAS_SERVER=http://localhost:3001

# ─── Atlas Telegram Bot (standalone) ──────────────────────────────────────────
ATLAS_SERVER_URL=http://localhost:3001

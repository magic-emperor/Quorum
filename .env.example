# ─────────────────────────────────────────────────────────────────────────────
# Qorum — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider Keys — set at least ONE ──────────────────────────────────────
# Any provider key works. Qorum will use whatever is configured.
QORUM_PROVIDER_ANTHROPIC_API_KEY=sk-ant-...   # https://console.anthropic.com/
# QORUM_PROVIDER_OPENAI_API_KEY=sk-...        # https://platform.openai.com/
# QORUM_PROVIDER_GOOGLE_API_KEY=...           # https://aistudio.google.com/
# QORUM_PROVIDER_DEEPSEEK_API_KEY=...         # https://platform.deepseek.com/
# QORUM_PROVIDER_DEEPSEEK_BASE_URL=           # optional: custom DeepSeek endpoint
# QORUM_PROVIDER_GROQ_API_KEY=gsk_...         # https://console.groq.com/
# QORUM_PROVIDER_MOONSHOT_API_KEY=...         # https://platform.moonshot.cn/ (Kimi)
# QORUM_PROVIDER_MISTRAL_API_KEY=...          # https://console.mistral.ai/
# QORUM_PROVIDER_OPENROUTER_API_KEY=sk-or-... # https://openrouter.ai/ (any model)

# ── Per-role provider + model overrides (optional) ───────────────────────────
# Roles: summarize, classify, plan, phase_split, testing, execute
# Example: use Groq for fast/cheap summarize, Claude for quality plan
# QORUM_ROLE_SUMMARIZE_PROVIDER=groq
# QORUM_ROLE_SUMMARIZE_MODEL=llama3-8b-8192
# QORUM_ROLE_PLAN_PROVIDER=anthropic
# QORUM_ROLE_PLAN_MODEL=claude-sonnet-4-6
# QORUM_ROLE_EXECUTE_PROVIDER=anthropic
# QORUM_ROLE_EXECUTE_MODEL=claude-sonnet-4-6

# ── Legacy model fields (still work; registry takes precedence above) ─────────
# QORUM_MODEL_DEFAULT=claude-sonnet-4-6
# QORUM_MODEL_FAST=claude-haiku-4-5-20251001
# QORUM_MODEL_PREMIUM=claude-opus-4-6

# ── Board Platform Tokens ──────────────────────────────────────────────────────
# Azure Boards
# AZURE_DEVOPS_PAT=...
# AZURE_DEVOPS_ORG=mycompany

# Jira Cloud
# JIRA_CLOUD_EMAIL=user@company.com
# JIRA_CLOUD_API_TOKEN=...
# JIRA_CLOUD_BASE_URL=https://mycompany.atlassian.net

# Jira Server (self-hosted)
# JIRA_SERVER_PAT=...
# JIRA_SERVER_BASE_URL=https://jira.mycompany.com

# GitHub
# GITHUB_TOKEN=ghp_...

# Linear
# LINEAR_API_KEY=lin_api_...

# ClickUp
# CLICKUP_API_TOKEN=...

# ── Bot Platform Tokens ────────────────────────────────────────────────────────
# Telegram
# TELEGRAM_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...       # for Socket Mode (dev)

# Discord
# DISCORD_BOT_TOKEN=...

# WhatsApp (Phase 13)
# QORUM_WHATSAPP_TOKEN=...
# QORUM_WHATSAPP_PHONE_ID=...
# QORUM_WHATSAPP_VERIFY_TOKEN=...
# QORUM_WHATSAPP_APP_SECRET=...

# Microsoft Teams (Phase 12)
# QORUM_TEAMS_APP_ID=...
# QORUM_TEAMS_APP_PASSWORD=...
# QORUM_TEAMS_TENANT_ID=...

# ── Paths & behaviour ─────────────────────────────────────────────────────────
# QORUM_OUTPUT_PATH=./qorum-output    # where plans are written (overridden per-repo in Phases 6–8)
# QORUM_DB_PATH=./qorum.db
# QORUM_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
# QORUM_MAX_CHILDREN=10
# QORUM_LARGE_TICKET_PHASE_LIMIT=5
# QORUM_PLATFORM_OVERRIDE=           # jira_server | azure_boards (for ambiguous URLs)
# QORUM_PLATFORM_BASE_URL=           # base URL when using QORUM_PLATFORM_OVERRIDE

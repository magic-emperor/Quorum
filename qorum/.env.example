# ============================================================
# Qorum — Environment Variables
# Copy this file to .env and fill in what you need.
# Every section is optional — configure only the platforms you use.
# NEVER commit .env to version control.
# ============================================================

# ── AI PROVIDERS (set at least one) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=

# Local model via Ollama / LM Studio (OpenAI-compatible)
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=ollama

# ── PER-ROLE MODEL ASSIGNMENT (optional) ────────────────────
# Defaults to Anthropic Claude for all roles.
# QORUM_ROLE_PLAN_PROVIDER=anthropic
# QORUM_ROLE_PLAN_MODEL=claude-sonnet-4-6
# QORUM_ROLE_CLASSIFY_PROVIDER=anthropic
# QORUM_ROLE_CLASSIFY_MODEL=claude-haiku-4-5-20251001
# QORUM_ROLE_EXECUTE_PROVIDER=anthropic
# QORUM_ROLE_EXECUTE_MODEL=claude-sonnet-4-6
# QORUM_ROLE_SUMMARIZE_PROVIDER=anthropic
# QORUM_ROLE_SUMMARIZE_MODEL=claude-haiku-4-5-20251001

# ── CHAT PLATFORMS ───────────────────────────────────────────

# Microsoft Teams
# Register at: https://dev.botframework.com/ or Azure Bot Service
QORUM_TEAMS_APP_ID=
QORUM_TEAMS_APP_PASSWORD=
# QORUM_TEAMS_TENANT_ID=  # optional: restrict to one tenant

# Slack (Socket Mode)
# Create at: https://api.slack.com/apps
# Required scopes: app_mentions:read, chat:write, channels:history, groups:history
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Discord
# Create at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Telegram
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp Cloud API
# Set up at: https://developers.facebook.com/docs/whatsapp
QORUM_WHATSAPP_TOKEN=
QORUM_WHATSAPP_PHONE_ID=

# ── ISSUE BOARDS ─────────────────────────────────────────────

# Jira Cloud
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_TOKEN=
JIRA_EMAIL=you@yourcompany.com
# Webhook (optional — instant ingestion instead of polling)
JIRA_WEBHOOK_SECRET=

# Azure Boards
# Token: https://dev.azure.com/{org}/_usersSettings/tokens
AZURE_DEVOPS_TOKEN=
AZURE_DEVOPS_ORG=your-org-name

# GitHub Issues
# Token: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=ghp_...
# Webhook (optional — instant ingestion instead of polling)
GITHUB_WEBHOOK_SECRET=

# Linear
# Token: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# ── DATABASE ─────────────────────────────────────────────────
# Local SQLite (default — no config needed, file created automatically)
QORUM_DB_PATH=./qorum.db

# Turso cloud SQLite (optional — replaces local file with cloud DB)
# Sign up free at https://turso.tech — 5GB free, 500M reads/month
# Run: turso db create qorum && turso db tokens create qorum
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# ── OUTPUT & LOGGING ─────────────────────────────────────────
QORUM_OUTPUT_PATH=./qorum-output
QORUM_LOG_LEVEL=INFO

# ── BEHAVIOUR ────────────────────────────────────────────────
# QORUM_PLATFORM_OVERRIDE=      # force a specific board platform
# QORUM_STOP_GRACE_SECONDS=20   # seconds before force-cancelling a run

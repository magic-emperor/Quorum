# ============================================================
# ATLAS BA Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── OUTPUT ──────────────────────────────────────────────────
# Where generated plan.md / testing.md / walkthrough.md files are saved.
# Defaults to ./atlas-output relative to where you run ATLAS.
ATLAS_OUTPUT_PATH=./atlas-output

# ── TICKET PLATFORMS ────────────────────────────────────────
# Configure at least ONE platform. ATLAS auto-detects platform from URL.

# Azure Boards
# Token scope required: Work Items (Read)
# Create at: https://dev.azure.com/{your-org}/_usersSettings/tokens
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG=your-org-name

# Jira Cloud
# Token scope: read:issue, read:project
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_CLOUD_EMAIL=you@yourcompany.com
JIRA_CLOUD_API_TOKEN=
JIRA_CLOUD_BASE_URL=https://yourcompany.atlassian.net

# Jira Server (self-hosted)
# Create a Personal Access Token in your Jira Server settings
JIRA_SERVER_PAT=
JIRA_SERVER_BASE_URL=https://jira.yourcompany.com

# GitHub
# Token scope: issues (read-only)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Linear
# Create at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# ClickUp
# Create at: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=

# ── PLATFORM FALLBACK ────────────────────────────────────────
# Use these if your URL doesn't match known patterns (e.g. self-hosted Jira).
# Supported values: azure_boards, jira_cloud, jira_server, github_issues, linear
# ATLAS_PLATFORM_OVERRIDE=jira_server
# ATLAS_PLATFORM_BASE_URL=https://jira.yourcompany.com

# ── CHAT BOTS ────────────────────────────────────────────────
# Configure at least ONE bot platform.

# Slack
# Create at: https://api.slack.com/apps
# Required scopes: commands, chat:write, files:write
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...   # Required for Socket Mode

# Discord
# Create at: https://discord.com/developers/applications
# Required permissions: Send Messages, Use Slash Commands, Attach Files
DISCORD_BOT_TOKEN=

# Telegram
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── STORAGE ──────────────────────────────────────────────────
# SQLite database for approval state (PENDING → APPROVED → DONE).
# Defaults to ./atlas.db — add to .gitignore.
ATLAS_DB_PATH=./atlas.db

# ── AI MODELS ────────────────────────────────────────────────
# Default: Sonnet 4.6 (best quality/cost balance)
# Fast: Haiku 4.5 (used for --brief flag)
# Premium: Opus 4.6 (opt-in for complex epics)
ATLAS_MODEL_DEFAULT=claude-sonnet-4-6
ATLAS_MODEL_FAST=claude-haiku-4-5-20251001
ATLAS_MODEL_PREMIUM=claude-opus-4-6

# ── BEHAVIOUR ────────────────────────────────────────────────
ATLAS_LOG_LEVEL=INFO
ATLAS_CACHE_TTL_HOURS=24
ATLAS_MAX_CHILDREN=10
ATLAS_LARGE_TICKET_PHASE_LIMIT=5

{
  "version": "1.0",
  "tier": "starter",
  "_tier_options": "starter | standard | professional",
  "_tier_starter": "Claude only — all agents use Claude models",
  "_tier_standard": "Claude + GPT-4o-mini for Critic (cross-company validation)",
  "_tier_professional": "Claude + GPT-4o + Gemini for large codebase analysis",

  "models": {
    "atlas-orchestrator":       "claude-opus-4-6",
    "atlas-classifier":         "claude-haiku-4-5-20251001",
    "atlas-critic":             "claude-haiku-4-5-20251001",
    "atlas-backend-architect":  "claude-sonnet-4-6",
    "atlas-backend-validator":  "claude-sonnet-4-6",
    "atlas-design-architect":   "claude-sonnet-4-6",
    "atlas-design-validator":   "claude-haiku-4-5-20251001",
    "atlas-frontend-builder":   "claude-sonnet-4-6",
    "atlas-integration":        "claude-sonnet-4-6",
    "atlas-testing":            "claude-sonnet-4-6",
    "atlas-scaling":            "claude-haiku-4-5-20251001",
    "atlas-nervous-system":     "claude-haiku-4-5-20251001"
  },

  "_upgrade_critic_standard": "Change atlas-critic to gpt-4o-mini for cross-company validation",
  "_upgrade_critic_professional": "Change atlas-critic to gpt-4o for strongest cross-company validation",
  "_upgrade_architect_professional": "Change atlas-backend-architect to gemini-1.5-pro for 2M context on large codebases",

  "frontend_builder": {
    "provider": "claude",
    "_provider_options": "claude | v0 | lovable",
    "v0_enabled": false,
    "lovable_enabled": false,
    "_v0_note": "Set v0_enabled: true and add V0_API_KEY to env to use v0 for frontend generation",
    "_lovable_note": "Lovable API not yet public — check lovable.dev for updates"
  },

  "token_budgets": {
    "_note": "Per-phase token budgets — orchestrator warns at 75%, checkpoints at 90%",
    "phase_0_foundation":          5000,
    "phase_1_architecture":        40000,
    "phase_2_design":              25000,
    "phase_3_build_per_module":    80000,
    "phase_4_integration":         30000,
    "phase_5_testing":             60000,
    "phase_6_scaling":             15000,
    "critic_per_intervention":     3000,
    "session_total_default":       300000
  },

  "budget_alerts": {
    "warning_threshold":   0.75,
    "checkpoint_threshold": 0.90,
    "exceeded_action": "checkpoint_and_notify"
  },

  "loop_limits": {
    "architect_validator_max_rounds": 3,
    "design_loop_max_rounds":         3,
    "bug_fix_max_attempts":           2,
    "integration_max_rounds":         2,
    "progress_threshold_percent":     5,
    "semantic_similarity_threshold":  0.85
  },

  "checkpoints": {
    "require_human_phase_1": true,
    "require_human_phase_2": true,
    "require_human_phase_5": true,
    "prompt_scaling_phase_6": true,
    "auto_proceed_simple_projects": true
  },

  "project": {
    "name": "",
    "description": "",
    "team_size": 1,
    "project_hash": ""
  }
}

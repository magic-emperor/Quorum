{
  "name": "quorum-vscode",
  "displayName": "QUORUM — Autonomous Development",
  "description": "Autonomous multi-agent development framework. One command builds your entire application.",
  "version": "1.1.0",
  "publisher": "quorum",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["AI", "autonomous", "agents", "development", "quorum"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "quorum.new",            "title": "QUORUM: New Feature",          "icon": "$(add)" },
      { "command": "quorum.enhance",        "title": "QUORUM: Enhance Feature",      "icon": "$(edit)" },
      { "command": "quorum.fast",           "title": "QUORUM: Fast Task",            "icon": "$(zap)" },
      { "command": "quorum.next",           "title": "QUORUM: What's Next?",         "icon": "$(arrow-right)" },
      { "command": "quorum.init",           "title": "QUORUM: Initialize Project",   "icon": "$(rocket)" },
      { "command": "quorum.doctor",         "title": "QUORUM: Doctor (Health Check)","icon": "$(heart)" },
      { "command": "quorum.status",         "title": "QUORUM: Status",               "icon": "$(pulse)" },
      { "command": "quorum.discuss",        "title": "QUORUM: Discuss Feature",      "icon": "$(comment-discussion)" },
      { "command": "quorum.verify",         "title": "QUORUM: Verify (UAT)",         "icon": "$(check-all)" },
      { "command": "quorum.ship",           "title": "QUORUM: Ship (Create PR)",     "icon": "$(git-pull-request)" },
      { "command": "quorum.review",         "title": "QUORUM: Code Review",          "icon": "$(eye)" },
      { "command": "quorum.map",            "title": "QUORUM: Map Codebase",         "icon": "$(map)" },
      { "command": "quorum.debug",          "title": "QUORUM: Debug Issue",          "icon": "$(bug)" },
      { "command": "quorum.sessionReport",  "title": "QUORUM: Session Report",       "icon": "$(notebook)" },
      { "command": "quorum.pause",          "title": "QUORUM: Pause Session",        "icon": "$(debug-pause)" },
      { "command": "quorum.resume",         "title": "QUORUM: Resume Session",       "icon": "$(debug-start)" },
      { "command": "quorum.sync",           "title": "QUORUM: Sync Index",           "icon": "$(sync)" },
      { "command": "quorum.rollback",       "title": "QUORUM: Rollback",             "icon": "$(discard)" },
      { "command": "quorum.agents",         "title": "QUORUM: List Agents",          "icon": "$(organization)" },
      { "command": "quorum.profile",        "title": "QUORUM: Switch Profile",       "icon": "$(settings-gear)" },
      { "command": "quorum.seed",           "title": "QUORUM: Capture Idea (Seed)",  "icon": "$(lightbulb)" },
      { "command": "quorum.note",           "title": "QUORUM: Quick Note",           "icon": "$(pencil)" },
      { "command": "quorum.backlog",        "title": "QUORUM: Backlog",              "icon": "$(list-unordered)" },
      { "command": "quorum.showPanel",      "title": "QUORUM: Show Panel",           "icon": "$(layout-sidebar-right)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quorum-sidebar",
          "title": "QUORUM",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "quorum-sidebar": [
        {
          "id": "quorum.panel",
          "name": "QUORUM",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        { "command": "quorum.review",   "group": "atlas@1", "when": "editorHasSelection || editorTextFocus" },
        { "command": "quorum.debug",    "group": "atlas@2" },
        { "command": "quorum.enhance",  "group": "atlas@3" }
      ],
      "view/title": [
        { "command": "quorum.next",   "group": "navigation", "when": "view == atlas.panel" },
        { "command": "quorum.status", "group": "navigation", "when": "view == atlas.panel" }
      ]
    },
    "keybindings": [
      { "command": "quorum.new",    "key": "ctrl+shift+a n", "mac": "cmd+shift+a n" },
      { "command": "quorum.next",   "key": "ctrl+shift+a x", "mac": "cmd+shift+a x" },
      { "command": "quorum.fast",   "key": "ctrl+shift+a f", "mac": "cmd+shift+a f" },
      { "command": "quorum.doctor", "key": "ctrl+shift+a d", "mac": "cmd+shift+a d" }
    ],
    "configuration": {
      "title": "QUORUM",
      "properties": {
        "quorum.projectDir": {
          "type": "string",
          "default": "",
          "description": "Override project directory (defaults to workspace root)"
        },
        "quorum.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open QUORUM panel on activation"
        },
        "quorum.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show QUORUM status bar item"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@quorum/core": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.4.0"
  }
}
